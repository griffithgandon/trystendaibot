# ===========================================================================
# Шаблон конфигурации. Скопируй в .env и заполни своими значениями.
# Имена переменных = имена полей в bot/config.py (pydantic-settings,
# регистронезависимо). Списки — через запятую, без пробелов.
# ===========================================================================

# ===== Bot =====
BOT_TOKEN=123456:ABC-DEF...                    # токен от @BotFather

# ===== Admins =====
ADMIN_IDS=111111111,222222222                  # БЫЛО ADMIN_ID -> стало ADMIN_IDS
ADMIN_USERNAMES=username1,username2            # без @

# ===== Database =====
DB_PATH=database/bot.db

# ===== Redis (опционально) =====
# Нужен только если в main.py выбрать RedisStorage для FSM.
# С MemoryStorage можно не запускать.
REDIS_URL=redis://localhost:6379/0

# ===== 3X-UI Panel =====
# PANEL_URL включает host:port + webBasePath (секретный префикс пути),
# но БЕЗ /panel/api/... — этот хвост добавляет код. Без слэша в конце.
PANEL_URL=https://your.host:port/webBasePath
API_TOKEN=                                     # Bearer-токен из панели: Settings -> API
# Inbound ID — ОПЦИОНАЛЬНО: если пусто/0, бот сам определит их с панели
# по протоколу инбаунда (vless / hysteria2). Заполняй только если нужно
# ограничить выдачу конкретными инбаундами.
VLESS_INBOUND_IDS=
HYSTERIA_INBOUND_ID=0
HYSTERIA_ENABLED=false
PANEL_VERIFY=true                               # true | false | /path/to/ca.crt

# ===== Subscription =====
SUB_BASE_URL=https://your.host:port/subBasePath # без слэша в конце
DOMAIN=your.host

# ===== Hysteria2 (опционально) =====
HYSTERIA_API_URL=
HYSTERIA_API_KEY=
HYSTERIA_HOST=
HYSTERIA_PORT=443
HYSTERIA_SNI=

# ===== Payment =====
SBP_NUMBER=+70000000000
CARD_NUMBER=2200000000000000

# ===== Trial =====
TRIAL_DAYS=7
TRIAL_AUTO_APPROVE=false

# ===== Servers =====
# БЫЛО SERVER1_NAME/SERVER1_URL -> стало SERVER_1_NAME/SERVER_1_URL
SERVER_1_NAME=Finland
SERVER_1_URL=https://your.host
SERVER_2_NAME=Poland
SERVER_2_URL=https://your.host2

# ===========================================================================
# ПРИМЕЧАНИЕ: тарифы (TARIFF_*_…) сейчас захардкожены в bot/config.py
# (свойство Settings.tariffs) и из .env НЕ читаются. Если нужно вынести
# их в .env — скажи, добавлю парсинг.
# ===========================================================================
